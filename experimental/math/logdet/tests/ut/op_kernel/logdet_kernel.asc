#include "kernel_operator.h"
#include "kernel_tiling/kernel_tiling.h"
#include "logdet_tiling_data.h"

using namespace AscendC;

constexpr int64_t FLOAT_ALIGN_ELEMENTS = 8;
constexpr int64_t OUT_ALIGN_ELEMENTS = 8;
constexpr int32_t BUFFER_NUM = 1;

__aicore__ inline int64_t AlignUp(int64_t value, int64_t align)
{
    return ((value + align - 1) / align) * align;
}

__aicore__ inline float AbsScalar(float value)
{
    return value >= 0.0f ? value : -value;
}

class KernelLogdetUt {
public:
    __aicore__ inline KernelLogdetUt() {}

    __aicore__ inline void Init(GM_ADDR self, GM_ADDR out, GM_ADDR workspace, const __gm__ LogdetTilingData* tilingData)
    {
        this->n = tilingData->matSizeN;
        this->matrixElements = n * n;
        this->alignedN = AlignUp(n, FLOAT_ALIGN_ELEMENTS);
        this->alignedMatrixElements = AlignUp(matrixElements, FLOAT_ALIGN_ELEMENTS);
        this->fullMatrixMode = true;

        const int64_t blockIdx = GetBlockIdx();
        baseMatrixIndex = blockIdx;
        blockMatrixCount = (blockIdx < static_cast<int64_t>(tilingData->matrixNumCount)) ? 1 : 0;

        selfGm.SetGlobalBuffer((__gm__ float*)self + baseMatrixIndex * matrixElements,
                               blockMatrixCount * matrixElements);
        workGm.SetGlobalBuffer((__gm__ float*)workspace + baseMatrixIndex * matrixElements,
                               blockMatrixCount * matrixElements);
        outGm.SetGlobalBuffer((__gm__ float*)out + baseMatrixIndex, blockMatrixCount);

        if (this->fullMatrixMode) {
            pipe.InitBuffer(inputQueue, BUFFER_NUM, alignedMatrixElements * sizeof(float));
            pipe.InitBuffer(fullWorkBuf, alignedMatrixElements * sizeof(float));
            pipe.InitBuffer(diagBuf, alignedN * sizeof(float));
            pipe.InitBuffer(outQueue, BUFFER_NUM, OUT_ALIGN_ELEMENTS * sizeof(float));
        }
    }

    __aicore__ inline void Process()
    {
        if (blockMatrixCount <= 0) {
            return;
        }
        for (int64_t matrixIdx = 0; matrixIdx < blockMatrixCount; ++matrixIdx) {
            float result = ComputeFullMatrix(matrixIdx);
            CopyOut(matrixIdx, result);
        }
    }

private:
    __aicore__ inline void CopyInFullMatrix(int64_t matrixIdx)
    {
        LocalTensor<float> inputLocal = inputQueue.AllocTensor<float>();
        DataCopyExtParams copyParams{
            1, static_cast<uint32_t>(matrixElements * sizeof(float)), 0, 0, 0};
        DataCopyPadExtParams<float> padParams{
            true, 0, static_cast<uint8_t>(alignedMatrixElements - matrixElements), 0.0f};
        DataCopyPad(inputLocal, selfGm[matrixIdx * matrixElements], copyParams, padParams);
        inputQueue.EnQue(inputLocal);
    }

    __aicore__ inline float ComputeFullMatrix(int64_t matrixIdx)
    {
        CopyInFullMatrix(matrixIdx);
        LocalTensor<float> inputLocal = inputQueue.DeQue<float>();
        LocalTensor<float> workLocal = fullWorkBuf.Get<float>();
        LocalTensor<float> diagLocal = diagBuf.Get<float>();

        for (int64_t idx = 0; idx < matrixElements; ++idx) {
            workLocal.SetValue(idx, inputLocal.GetValue(idx));
        }

        int32_t parity = 0;
        bool singular = false;
        for (int64_t k = 0; k < n; ++k) {
            int64_t pivotRow = k;
            float maxAbs = AbsScalar(workLocal.GetValue(k * n + k));

            for (int64_t row = k + 1; row < n; ++row) {
                float value = workLocal.GetValue(row * n + k);
                float absValue = AbsScalar(value);
                if (absValue > maxAbs) {
                    maxAbs = absValue;
                    pivotRow = row;
                }
            }

            if (maxAbs == 0.0f) {
                singular = true;
                break;
            }

            if (pivotRow != k) {
                for (int64_t col = k; col < n; ++col) {
                    float top = workLocal.GetValue(k * n + col);
                    float bottom = workLocal.GetValue(pivotRow * n + col);
                    workLocal.SetValue(k * n + col, bottom);
                    workLocal.SetValue(pivotRow * n + col, top);
                }
                parity ^= 1;
            }

            const float pivot = workLocal.GetValue(k * n + k);
            for (int64_t row = k + 1; row < n; ++row) {
                const float factor = workLocal.GetValue(row * n + k) / pivot;
                for (int64_t col = k + 1; col < n; ++col) {
                    const float updated =
                        workLocal.GetValue(row * n + col) - factor * workLocal.GetValue(k * n + col);
                    workLocal.SetValue(row * n + col, updated);
                }
                workLocal.SetValue(row * n + k, 0.0f);
            }
        }

        if (singular) {
            inputQueue.FreeTensor(inputLocal);
            return -__builtin_inff();
        }

        Duplicate(diagLocal, 1.0f, static_cast<uint32_t>(alignedN));

        int32_t detSign = (parity & 1) == 0 ? 1 : -1;
        for (int64_t i = 0; i < n; ++i) {
            const float diag = workLocal.GetValue(i * n + i);
            diagLocal.SetValue(i, diag);
            if (diag > 0.0f) {
                continue;
            }
            if (diag < 0.0f) {
                detSign = -detSign;
            } else {
                detSign = 0;
            }
        }

        if (detSign < 0) {
            inputQueue.FreeTensor(inputLocal);
            return __builtin_nanf("");
        }
        if (detSign == 0) {
            inputQueue.FreeTensor(inputLocal);
            return -__builtin_inff();
        }

        Abs(diagLocal, diagLocal, static_cast<uint32_t>(alignedN));
        Ln(diagLocal, diagLocal, static_cast<uint32_t>(alignedN));

        float result = 0.0f;
        for (int64_t i = 0; i < n; ++i) {
            result += diagLocal.GetValue(i);
        }
        inputQueue.FreeTensor(inputLocal);
        return result;
    }

    __aicore__ inline void CopyOut(int64_t matrixIdx, float result)
    {
        LocalTensor<float> outLocal = outQueue.AllocTensor<float>();
        outLocal.SetValue(0, result);
        outQueue.EnQue<float>(outLocal);
        LocalTensor<float> outTensor = outQueue.DeQue<float>();
        DataCopyExtParams copyParams{
            1, static_cast<uint32_t>(sizeof(float)), 0, 0, 0};
        DataCopyPad(outGm[matrixIdx], outTensor, copyParams);
        outQueue.FreeTensor(outTensor);
    }

private:
    TPipe pipe;
    TQue<TPosition::VECIN, BUFFER_NUM> inputQueue;
    TQue<TPosition::VECOUT, BUFFER_NUM> outQueue;
    TBuf<TPosition::VECCALC> fullWorkBuf;
    TBuf<TPosition::VECCALC> diagBuf;
    GlobalTensor<float> selfGm;
    GlobalTensor<float> workGm;
    GlobalTensor<float> outGm;
    int64_t n = 0;
    int64_t alignedN = 0;
    int64_t matrixElements = 0;
    int64_t alignedMatrixElements = 0;
    int64_t baseMatrixIndex = 0;
    int64_t blockMatrixCount = 0;
    bool fullMatrixMode = false;
};

extern "C" __global__ __aicore__ void logdet_kernel(GM_ADDR self, GM_ADDR out, GM_ADDR workspace, GM_ADDR tiling)
{
    KernelLogdetUt op;
    op.Init(self, out, workspace, (__gm__ LogdetTilingData*)tiling);
    op.Process();
}
